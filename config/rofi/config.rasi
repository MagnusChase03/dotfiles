configuration{
    modi: "run,drun,window";
    icon-theme: "Tela Circle Black Dark";
    show-icons: true;
    terminal: "kitty";
    drun-display-format: "{icon} {name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-drun: " Apps ";
}

@theme "catppuccin-frappe"
