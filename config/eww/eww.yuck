(defwindow bar
    :monitor 0
    :geometry (
        geometry :x "0%"
                 :y "0%"
                 :width "100%"
                 :height "42px"
                 :anchor "bottom center")
    :stacking "fg"
    :reserve (
        struts :distance "50px"
               :side "bottom")
    :windowtype "dock"
    :wm-ignore false
    :exclusive true

    (bar))

(defwidget bar []
    (centerbox :orientation "horizontal"
               :class "bar"

               (left)
               (center)
               (right)))

(defwidget left [] 
    (box :orientation "horizontal"
         :class "left"
         :halign "start"
         :valign "center"
         (workspaces)))

(defwidget workspaces []
    (literal :content workspace))

(defwidget center []
    (box :orientation "horizontal"
         :class "center"))

(defwidget right []
    (box :orientation "horizontal"
         :halign "end"
         :class "right"
         :space-evenly false
         :spacing "30"
         (volume)
         (battery)
         (clock)
         (power)))

(defwidget volume []
    (eventbox :onhover "eww update vol_rev=true"
              :onhoverlost "eww update vol_rev=false"
              (box :orientation "horizontal"
                   :class "volume_module"
                   :space-evenly false
                   (label :text "󰕾 "
                          :class "volume")
                   (revealer :transition "slideleft"
                             :reveal vol_rev
                             :duration "350ms"
                             (box :orientation "horizontal"
                                  :space-evenly false
                                  (label :text "${volume_percent}%")
                                  (scale :class "volume_slider"
                                         :orientation "horizontal"
                                         :min 0
                                         :max 100
                                         :value volume_percent
                                         :onchange "pamixer --set-volume {}"))))))

(defwidget battery []
    (box :orientation "horizontal"
        :class "battery"
        (label :text "" 
               :class "battery_icon"
               :tooltip "Battery: ${battery}%")))

(defwidget clock []
    (eventbox :onhover "eww update time_rev=true"
              :onhoverlost "eww update time_rev=false"
              (box :orientation "horizontal"
                   :class "clock"
                   :space-evenly false
                   (label :class "time"
                          :text "   ${time}")
                   (revealer :transition "slideleft"
                             :reveal time_rev
                             :duration "350ms"
                             (button :class "date"
                                     :onclick "eww open calender"
                                     date)))))

(defwidget power []
    (button :onclick "eww open power_menu"
            :class "power"
            "⏻"))

(defpoll volume_percent :interval "3s" "pamixer --get-volume")
(defpoll time :interval "5s" "date +%H:%M")
(defpoll date :interval "1m" "date +%m/%d")
(defpoll battery :interval "1m" "cat /sys/class/power_supply/BAT1/capacity")
(defvar time_rev false)
(defvar vol_rev false)
(deflisten workspace "./scripts/workspaces.sh")

(defwindow calender
    :monitor 0
    :geometry (
        geometry :x "20px"
                 :y "20px"
                 :width "20%"
                 :anchor "bottom right")
    :stacking "fg"
    :wm-ignore false

    (calender))

(defwidget calender []
    (box :orientation "vertical"
         :class "calender"
         :space-evenly false
         (calender_controls)
         (calendar)))

(defwidget calender_controls []
    (box :orientation "horizontal"
         :halign "end"
         :class "calender_controls"
         (button :onclick "eww close calender"
                 "")))

(defwindow power_menu
    :monitor 0
    :geometry (
        geometry :x "20px"
                 :y "20px"
                 :width "15%"
                 :anchor "bottom right")
    :stacking "fg"
    :wm-ignore false

    (power_menu))

(defwidget power_menu []
    (box :orientation "vertical"
         :space-evenly false
         :class "power_menu"
         (power_menu_controls)
         (brightness)
         (power_buttons)))

(defwidget power_menu_controls []
    (box :orientation "horizontal"
         :halign "end"
         :class "power_menu_controls"
         (button :onclick "eww close power_menu"
                 "")))

(defwidget brightness []
    (box :orientation "horizontal"
         :space-evenly false
         :class "brightness"
         (label :class "brightness_icon"
                :text "󰃞")
         (scale :class "brightness_slider"
                :orientation "horizontal"
                :min 1200
                :max brightness_max
                :value brightness_percent
                :onchange "brightnessctl s {}")))

(defwidget power_buttons []
    (box :orientation "horizontal"
         :class "power_buttons"
         :spacing "10"
         (button :onclick "sudo restart"
                 :class "power_button"
                 "")
         (button :onclick "sudo poweroff"
                 :class "power_button"
                 "⏻")))

(defvar brightness_max 24000)
(defpoll brightness_percent :interval "5s" "brightnessctl g")
